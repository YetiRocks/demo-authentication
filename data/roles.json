[
  {
    "id": "super_user",
    "name": "Super User",
    "permission": { "super_user": true, "databases": {} }
  },
  {
    "id": "admin",
    "name": "Admin",
    "permission": {
      "databases": {
        "demo-authentication": {
          "tables": {
            "Employee": { "read": true, "insert": true, "update": true, "delete": true }
          }
        }
      }
    }
  },
  {
    "id": "viewer",
    "name": "Viewer",
    "permission": {
      "databases": {
        "data": {
          "tables": {
            "*": { "read": true, "insert": false, "update": false, "delete": false }
          }
        },
        "demo-authentication": {
          "tables": {
            "Employee": {
              "read": true, "insert": false, "update": false, "delete": false,
              "attribute_permissions": {
                "salary": { "read": false, "write": false },
                "ssn": { "read": false, "write": false },
                "homeAddress": { "read": false, "write": false },
                "personalEmail": { "read": false, "write": false }
              }
            }
          }
        }
      }
    }
  }
]
